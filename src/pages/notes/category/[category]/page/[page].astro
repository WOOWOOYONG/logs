---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import CategoryNav from '@/components/CategoryNav.astro';
import Pagination from '@/components/Pagination.astro';
import {
  CATEGORIES,
  getCategory,
  getCategoryName,
  type CategorySlug,
} from '@/utils/category';
import { NOTES_PAGE_SIZE, SITE_TITLE } from '@/consts';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const isProd = import.meta.env.PROD;
  const notes = (
    await getCollection('notes', ({ data }) => (isProd ? !data.draft : true))
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const counts: Partial<Record<CategorySlug, number>> = {};
  for (const category of CATEGORIES) counts[category.slug] = 0;
  const byCat: Partial<Record<CategorySlug, typeof notes>> = {};
  for (const note of notes) {
    const category = getCategory(note.data.tags);
    counts[category] = (counts[category] ?? 0) + 1;
    (byCat[category] ??= []).push(note);
  }

  return CATEGORIES.flatMap((category) => {
    const items = byCat[category.slug] ?? [];
    const pages = paginate(items, {
      pageSize: NOTES_PAGE_SIZE,
      params: { category: category.slug },
      props: { slug: category.slug, counts, total: notes.length },
    });
    return pages.filter((path) => path.params.page !== '1');
  });
}

const { page, slug, counts, total } = Astro.props;
const name = getCategoryName(slug);
---

<Layout title={`${name} · Page ${page.currentPage} · Notes · ${SITE_TITLE}`}>
  <header class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">Notes</h1>
    <p class="mt-1 text-sm text-neutral-500">分類：{name}</p>
  </header>

  <div class="md:flex md:gap-10">
    <CategoryNav counts={counts} total={total} active={slug} />

    <div class="mt-6 min-w-0 flex-1 md:mt-0">
      {page.data.map((note) => (
        <PostCard
          href={`/notes/${note.id}`}
          title={note.data.title}
          description={note.data.description}
          pubDate={note.data.pubDate}
          tags={note.data.tags}
        />
      ))}

      <Pagination page={page} basePath={`/notes/category/${slug}`} />
    </div>
  </div>
</Layout>
