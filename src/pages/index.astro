---
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';
import TechPill from '@/components/TechPill.astro';
import avatar from '@/assets/images/y-cap.png';

const techs = ['Vue', 'Nuxt', 'TypeScript', 'Tailwind'] as const;
---

<Layout>
  <section class="flex flex-col items-center text-center">
    <Image
      src={avatar}
      alt="WOOWOOYONG 的個人照片"
      width={120}
      height={120}
      class="mb-5 h-28 w-28 rounded-full object-cover ring-2 ring-neutral-200"
    />
    <h1 class="text-2xl font-semibold tracking-tight">WOOWOOYONG</h1>
    <p class="mt-1 text-sm font-medium text-neutral-500">Frontend Developer</p>

    <div class="mt-6 max-w-md space-y-3 text-neutral-600 leading-relaxed">
      <p>這裡是我記錄技術筆記、專案與日常想法的地方。</p>
      <p>目前努力在這 AI 浪潮中載浮載沉 🫠</p>
    </div>

    <div class="mt-8 w-full max-w-md">
      <div class="flex items-center gap-3">
        <span class="h-px flex-1 bg-neutral-200"></span>
        <span class="text-xs font-medium tracking-widest text-neutral-400 uppercase">Stack</span>
        <span class="h-px flex-1 bg-neutral-200"></span>
      </div>
      <ul class="mt-4 flex flex-wrap justify-center gap-2">
        {techs.map((name) => <TechPill name={name} />)}
      </ul>
    </div>
  </section>
</Layout>
