---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import TagList from './TagList.astro'

interface Props {
  href: string
  title: string
  description: string
  cover: ImageMetadata
  tags?: string[]
}
const { href, title, description, cover, tags = [] } = Astro.props
---

<a
  href={href}
  class="group block overflow-hidden rounded-xl border border-neutral-200 transition hover:border-neutral-400 dark:border-[var(--ds-gray-alpha-400)] dark:bg-[var(--ds-background-100)] dark:hover:border-[var(--ds-gray-600)]"
>
  <div class="aspect-[16/10] overflow-hidden bg-neutral-100 dark:bg-[var(--ds-gray-100)]">
    <Image
      src={cover}
      alt={title}
      class="h-full w-full object-cover transition group-hover:scale-[1.02]"
      widths={[480, 800, 1200]}
      sizes="(min-width: 768px) 50vw, 100vw"
    />
  </div>
  <div class="p-4">
    <h3 class="text-base font-medium underline-offset-4 group-hover:underline">{title}</h3>
    <p class="mt-1 line-clamp-2 text-sm text-neutral-600 dark:text-[var(--ds-gray-900)]">
      {description}
    </p>
    {
      tags.length > 0 && (
        <div class="mt-3">
          <TagList tags={tags} size="xs" />
        </div>
      )
    }
  </div>
</a>
