---
interface Props {
  page: {
    currentPage: number
    lastPage: number
  }
  basePath?: string
}
const { page, basePath = '/notes' } = Astro.props
const { currentPage, lastPage } = page

const hrefFor = (n: number) => (n === 1 ? basePath : `${basePath}/page/${n}`)
const prev = currentPage > 1 ? hrefFor(currentPage - 1) : undefined
const next = currentPage < lastPage ? hrefFor(currentPage + 1) : undefined
const pages = Array.from({ length: lastPage }, (_, i) => i + 1)
---

{
  lastPage > 1 && (
    <nav class="mt-10 flex items-center justify-center gap-2 text-sm" aria-label="Pagination">
      {prev ? (
        <a
          href={prev}
          class="rounded border border-neutral-200 px-3 py-1 transition-colors hover:bg-neutral-100 dark:border-(--ds-gray-alpha-400) dark:hover:bg-(--ds-gray-100)"
        >
          ← 上一頁
        </a>
      ) : (
        <span class="pointer-events-none rounded border border-neutral-200 px-3 py-1 text-neutral-300 dark:border-(--ds-gray-400) dark:text-(--ds-gray-500)">
          ← 上一頁
        </span>
      )}

      {pages.map((n) =>
        n === currentPage ? (
          <span
            aria-current="page"
            class="rounded bg-neutral-900 px-3 py-1 text-white dark:bg-(--ds-gray-1000) dark:text-(--ds-background-200)"
          >
            {n}
          </span>
        ) : (
          <a
            href={hrefFor(n)}
            class="rounded border border-neutral-200 px-3 py-1 transition-colors hover:bg-neutral-100 dark:border-(--ds-gray-alpha-400) dark:hover:bg-(--ds-gray-100)"
          >
            {n}
          </a>
        ),
      )}

      {next ? (
        <a
          href={next}
          class="rounded border border-neutral-200 px-3 py-1 transition-colors hover:bg-neutral-100 dark:border-(--ds-gray-alpha-400) dark:hover:bg-(--ds-gray-100)"
        >
          下一頁 →
        </a>
      ) : (
        <span class="pointer-events-none rounded border border-neutral-200 px-3 py-1 text-neutral-300 dark:border-(--ds-gray-400) dark:text-(--ds-gray-500)">
          下一頁 →
        </span>
      )}
    </nav>
  )
}
