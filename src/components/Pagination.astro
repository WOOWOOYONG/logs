---
interface Props {
  page: {
    currentPage: number;
    lastPage: number;
  };
  basePath?: string;
}
const { page, basePath = '/notes' } = Astro.props;
const { currentPage, lastPage } = page;

const hrefFor = (pageNum: number) => (pageNum === 1 ? basePath : `${basePath}/page/${pageNum}`);
const prev = currentPage > 1 ? hrefFor(currentPage - 1) : undefined;
const next = currentPage < lastPage ? hrefFor(currentPage + 1) : undefined;
const pages = Array.from({ length: lastPage }, (_, index) => index + 1);
---

{lastPage > 1 && (
  <nav class="mt-10 flex items-center justify-center gap-2 text-sm" aria-label="Pagination">
    {prev ? (
      <a href={prev} class="rounded border border-neutral-200 px-3 py-1 hover:bg-neutral-100">← 上一頁</a>
    ) : (
      <span class="pointer-events-none rounded border border-neutral-200 px-3 py-1 text-neutral-300">← 上一頁</span>
    )}

    {pages.map((pageNum) => (
      pageNum === currentPage ? (
        <span aria-current="page" class="rounded bg-neutral-900 px-3 py-1 text-white">{pageNum}</span>
      ) : (
        <a href={hrefFor(pageNum)} class="rounded border border-neutral-200 px-3 py-1 hover:bg-neutral-100">{pageNum}</a>
      )
    ))}

    {next ? (
      <a href={next} class="rounded border border-neutral-200 px-3 py-1 hover:bg-neutral-100">下一頁 →</a>
    ) : (
      <span class="pointer-events-none rounded border border-neutral-200 px-3 py-1 text-neutral-300">下一頁 →</span>
    )}
  </nav>
)}
