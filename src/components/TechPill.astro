---
type Tech = 'Vue' | 'Nuxt' | 'TypeScript' | 'Tailwind'

interface Props {
  name: Tech
}

const { name } = Astro.props

const styles: Record<Tech, string> = {
  Vue: 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/80 dark:bg-emerald-950/60 dark:text-emerald-300',
  Nuxt: 'border-green-200 bg-green-50 text-green-800 dark:border-green-900/80 dark:bg-green-950/60 dark:text-green-300',
  TypeScript:
    'border-blue-200 bg-blue-50 text-blue-700 dark:border-blue-900/80 dark:bg-blue-950/60 dark:text-blue-300',
  Tailwind:
    'border-sky-200 bg-sky-50 text-sky-700 dark:border-sky-900/80 dark:bg-sky-950/60 dark:text-sky-300',
}
---

<li
  class={`rounded-full border px-3 py-1 text-xs font-medium transition hover:brightness-95 ${styles[name]}`}
>
  {name}
</li>
