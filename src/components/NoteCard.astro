---
import TagList from './TagList.astro'

interface Props {
  pubDate: Date
  tags?: string[]
}
const { pubDate, tags = [] } = Astro.props
const dateStr = pubDate.toISOString().slice(0, 10)

function relative(date: Date) {
  const diffMs = Date.now() - date.valueOf()
  const sec = Math.round(diffMs / 1000)
  if (sec < 60) return '剛剛'
  const min = Math.round(sec / 60)
  if (min < 60) return `${min} 分鐘前`
  const hr = Math.round(min / 60)
  if (hr < 24) return `${hr} 小時前`
  const day = Math.round(hr / 24)
  if (day < 30) return `${day} 天前`
  const mon = Math.round(day / 30)
  if (mon < 12) return `${mon} 個月前`
  return `${Math.round(mon / 12)} 年前`
}
---

<article
  class="rounded-xl border border-neutral-200 p-5 dark:border-(--ds-gray-alpha-400) dark:bg-(--ds-background-100)"
>
  <header
    class="mb-2 flex items-center justify-between text-xs text-neutral-500 dark:text-(--ds-gray-600)"
  >
    <time datetime={dateStr} title={dateStr}>{relative(pubDate)}</time>
    {tags.length > 0 && <TagList tags={tags} size="xs" />}
  </header>
  <div class="prose-basic text-sm">
    <slot />
  </div>
</article>
