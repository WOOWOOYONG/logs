---
import { Icon } from 'astro-icon/components'
import { SITE_TITLE } from '@/consts'

const pathname = Astro.url.pathname
const links = [
  { href: '/', label: 'Home' },
  { href: '/notes', label: 'Notes' },
  { href: '/projects', label: 'Projects' },
  { href: '/logs', label: 'Logs' },
]

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname === href || pathname.startsWith(href + '/')
}
---

<nav class="border-b border-neutral-200 dark:border-neutral-800">
  <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
    <a href="/" class="font-bold tracking-tight dark:text-neutral-100">{SITE_TITLE}</a>

    <ul class="hidden gap-5 text-sm sm:flex">
      {
        links.slice(1).map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'font-semibold transition-colors hover:text-black dark:hover:text-neutral-100',
                isActive(link.href)
                  ? 'font-bold text-black dark:text-neutral-100'
                  : 'text-neutral-500 dark:text-neutral-400',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-1">
      <button
        type="button"
        id="theme-toggle"
        aria-label="切換深色模式"
        aria-pressed="false"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-neutral-700 transition-colors hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800"
      >
        <Icon name="lucide:sun" class="hidden h-5 w-5 dark:block" />
        <Icon name="lucide:moon" class="block h-5 w-5 dark:hidden" />
      </button>

      <button
        type="button"
        id="nav-open"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-neutral-700 transition-colors hover:bg-neutral-100 sm:hidden dark:text-neutral-300 dark:hover:bg-neutral-800"
      >
        <Icon name="lucide:menu" class="h-5 w-5" />
      </button>
    </div>
  </div>
</nav>

<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
  class="invisible fixed inset-0 z-50 bg-white opacity-0 transition-opacity duration-200 sm:hidden dark:bg-neutral-950"
>
  <div
    class="flex h-16 items-center justify-between border-b border-neutral-200 px-4 dark:border-neutral-800"
  >
    <span class="font-semibold tracking-tight dark:text-neutral-100">{SITE_TITLE}</span>
    <button
      type="button"
      id="nav-close"
      aria-label="Close menu"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md text-neutral-700 transition-colors hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800"
    >
      <Icon name="lucide:x" class="h-5 w-5" />
    </button>
  </div>

  <ul class="flex flex-col px-4 py-4">
    {
      links.slice(1).map((link) => (
        <li>
          <a
            href={link.href}
            data-nav-link
            class:list={[
              'block py-3 text-lg font-medium transition-colors hover:text-black dark:hover:text-neutral-100',
              isActive(link.href)
                ? 'font-bold text-black dark:text-neutral-100'
                : 'text-neutral-600 dark:text-neutral-400',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  const storageKey = 'theme'
  const root = document.documentElement
  const systemTheme = window.matchMedia('(prefers-color-scheme: dark)')
  const themeToggle = document.getElementById('theme-toggle')
  const openBtn = document.getElementById('nav-open')
  const closeBtn = document.getElementById('nav-close')
  const menu = document.getElementById('mobile-menu')
  const navLinks = menu?.querySelectorAll<HTMLAnchorElement>('[data-nav-link]')

  function getStoredTheme() {
    try {
      return localStorage.getItem(storageKey)
    } catch {
      return null
    }
  }

  function setStoredTheme(value: 'light' | 'dark') {
    try {
      localStorage.setItem(storageKey, value)
    } catch {
      return
    }
  }

  function applyTheme(isDark: boolean) {
    root.classList.toggle('dark', isDark)
    root.style.colorScheme = isDark ? 'dark' : 'light'
    themeToggle?.setAttribute('aria-pressed', String(isDark))
    themeToggle?.setAttribute('aria-label', isDark ? '切換為淺色模式' : '切換為深色模式')
  }

  function toggleTheme() {
    const isDark = !root.classList.contains('dark')
    setStoredTheme(isDark ? 'dark' : 'light')
    applyTheme(isDark)
  }

  function syncWithSystem(event: MediaQueryListEvent) {
    if (getStoredTheme()) return
    applyTheme(event.matches)
  }

  function openMenu() {
    if (!menu || !openBtn) return
    menu.classList.remove('invisible', 'opacity-0')
    menu.classList.add('opacity-100')
    openBtn.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  }

  function closeMenu() {
    if (!menu || !openBtn) return
    menu.classList.add('invisible', 'opacity-0')
    menu.classList.remove('opacity-100')
    openBtn.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }

  applyTheme(root.classList.contains('dark'))
  themeToggle?.addEventListener('click', toggleTheme)
  systemTheme.addEventListener?.('change', syncWithSystem)
  openBtn?.addEventListener('click', openMenu)
  closeBtn?.addEventListener('click', closeMenu)
  navLinks?.forEach((link) => link.addEventListener('click', closeMenu))
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu()
  })
</script>
