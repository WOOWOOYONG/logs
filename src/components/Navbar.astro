---
import { Icon } from 'astro-icon/components'
import { SITE_TITLE } from '@/consts'

const pathname = Astro.url.pathname
const links = [
  { href: '/', label: 'Home' },
  { href: '/notes', label: 'Notes' },
  { href: '/projects', label: 'Projects' },
  { href: '/logs', label: 'Logs' },
]

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname === href || pathname.startsWith(href + '/')
}
---

<nav class="border-b border-neutral-200">
  <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
    <a href="/" class="font-semibold tracking-tight">{SITE_TITLE}</a>

    <ul class="hidden gap-5 text-sm sm:flex">
      {
        links.slice(1).map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'font-medium transition-colors hover:text-black',
                isActive(link.href) ? 'font-bold text-black' : 'text-neutral-500',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      type="button"
      id="nav-open"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md text-neutral-700 hover:bg-neutral-100 sm:hidden"
    >
      <Icon name="lucide:menu" class="h-5 w-5" />
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
  class="invisible fixed inset-0 z-50 bg-white opacity-0 transition-opacity duration-200 sm:hidden"
>
  <div class="flex h-16 items-center justify-between border-b border-neutral-200 px-4">
    <span class="font-semibold tracking-tight">{SITE_TITLE}</span>
    <button
      type="button"
      id="nav-close"
      aria-label="Close menu"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md text-neutral-700 hover:bg-neutral-100"
    >
      <Icon name="lucide:x" class="h-5 w-5" />
    </button>
  </div>

  <ul class="flex flex-col px-4 py-4">
    {
      links.slice(1).map((link) => (
        <li>
          <a
            href={link.href}
            data-nav-link
            class:list={[
              'block py-3 text-lg font-medium transition-colors hover:text-black',
              isActive(link.href) ? 'font-bold text-black' : 'text-neutral-600',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  const openBtn = document.getElementById('nav-open')
  const closeBtn = document.getElementById('nav-close')
  const menu = document.getElementById('mobile-menu')
  const navLinks = menu?.querySelectorAll<HTMLAnchorElement>('[data-nav-link]')

  function openMenu() {
    if (!menu || !openBtn) return
    menu.classList.remove('invisible', 'opacity-0')
    menu.classList.add('opacity-100')
    openBtn.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  }

  function closeMenu() {
    if (!menu || !openBtn) return
    menu.classList.add('invisible', 'opacity-0')
    menu.classList.remove('opacity-100')
    openBtn.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }

  openBtn?.addEventListener('click', openMenu)
  closeBtn?.addEventListener('click', closeMenu)
  navLinks?.forEach((link) => link.addEventListener('click', closeMenu))
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu()
  })
</script>
