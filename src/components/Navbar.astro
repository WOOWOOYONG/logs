---
import { SITE_TITLE } from '@/consts'

const pathname = Astro.url.pathname
const links = [
  { href: '/', label: 'Home' },
  { href: '/notes', label: 'Notes' },
  { href: '/projects', label: 'Projects' },
  { href: '/logs', label: 'Logs' },
]

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname === href || pathname.startsWith(href + '/')
}
---

<nav class="border-b border-neutral-200">
  <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
    <a href="/" class="font-semibold tracking-tight">{SITE_TITLE}</a>
    <ul class="flex gap-5 text-sm">
      {
        links.slice(1).map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'font-medium transition-colors hover:text-black',
                isActive(l.href) ? 'font-bold text-black' : 'text-neutral-500',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
